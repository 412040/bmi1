<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BMI 健康管理助手</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lucide/0.263.0/lucide.min.js"></script>
    <style>
        body {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'PingFang TC', 'Microsoft JhengHei', sans-serif;
            padding: 20px;
        }
        .card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-radius: 2rem;
            box-shadow: 0 20px 50px rgba(0,0,0,0.05);
            width: 100%;
            max-width: 500px;
            overflow: hidden;
        }
        .bmi-bar {
            height: 12px;
            border-radius: 6px;
            background: #e5e7eb;
            position: relative;
            overflow: hidden;
        }
        .bmi-indicator {
            position: absolute;
            height: 100%;
            width: 0%;
            transition: width 1s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .history-item {
            animation: slideIn 0.3s ease-out;
        }
        @keyframes slideIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .custom-shadow {
            box-shadow: 0 4px 14px 0 rgba(79, 70, 229, 0.3);
        }
    </style>
</head>
<body>

<div class="card">
    <!-- 頂部裝飾 -->
    <div class="h-2 bg-indigo-600"></div>
    
    <div class="p-8">
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-black text-gray-800">BMI 智享健康</h1>
                <p class="text-gray-400 text-xs">身體質量指數專業分析</p>
            </div>
            <div class="bg-indigo-50 p-3 rounded-2xl text-indigo-600">
                <i data-lucide="activity"></i>
            </div>
        </div>
        
        <div class="space-y-6">
            <div class="grid grid-cols-2 gap-4">
                <div class="space-y-2">
                    <label class="block text-xs font-bold text-gray-500 uppercase ml-1">身高 (cm)</label>
                    <input type="number" id="height" placeholder="例如 175" 
                           class="w-full px-4 py-3 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-indigo-500 transition-all text-lg font-semibold">
                </div>
                <div class="space-y-2">
                    <label class="block text-xs font-bold text-gray-500 uppercase ml-1">體重 (kg)</label>
                    <input type="number" id="weight" placeholder="例如 70" 
                           class="w-full px-4 py-3 bg-gray-50 border-none rounded-2xl focus:ring-2 focus:ring-indigo-500 transition-all text-lg font-semibold">
                </div>
            </div>

            <button onclick="calculateBMI()" 
                    class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-4 rounded-2xl transition-all custom-shadow active:scale-95 flex items-center justify-center gap-2 text-lg">
                <i data-lucide="calculator" class="w-5 h-5"></i> 獲取分析報告
            </button>

            <!-- 結果區塊 -->
            <div id="resultArea" class="hidden space-y-4">
                <div id="resultBox" class="p-6 rounded-3xl border-2 transition-all duration-500">
                    <div class="flex justify-between items-start mb-4">
                        <span id="statusBadge" class="px-3 py-1 rounded-full text-xs font-black uppercase tracking-wider">分析中</span>
                        <div class="text-right">
                            <span class="text-xs text-gray-400 block">您的指數</span>
                            <span id="bmiValue" class="text-4xl font-black italic">0.0</span>
                        </div>
                    </div>
                    
                    <!-- 視覺化進度條 -->
                    <div class="bmi-bar mb-4">
                        <div id="bmiIndicator" class="bmi-indicator bg-current"></div>
                    </div>

                    <div class="bg-white/50 rounded-2xl p-4 text-left">
                        <h4 class="text-sm font-bold mb-1 flex items-center gap-2">
                            <i data-lucide="heart" class="w-4 h-4 text-red-500"></i> 健康醫師建議
                        </h4>
                        <p id="bmiAdvice" class="text-sm leading-relaxed text-gray-600"></p>
                    </div>
                </div>

                <!-- 歷史紀錄 -->
                <div class="mt-8">
                    <div class="flex items-center justify-between mb-3 px-1">
                        <h3 class="text-sm font-black text-gray-400 uppercase">近期紀錄</h3>
                        <button onclick="clearHistory()" class="text-[10px] text-gray-300 hover:text-red-400 transition-colors">清除全部</button>
                    </div>
                    <div id="historyList" class="space-y-2 max-h-40 overflow-y-auto pr-1">
                        <!-- 歷史紀錄將插入在此 -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // 初始化圖標
    lucide.createIcons();

    let history = [];

    function calculateBMI() {
        const heightInput = document.getElementById('height');
        const weightInput = document.getElementById('weight');
        const h = parseFloat(heightInput.value);
        const w = parseFloat(weightInput.value);

        if (!h || !w || h <= 0 || w <= 0) {
            showToast('請輸入有效的身高與體重資料');
            return;
        }

        const bmi = (w / Math.pow(h / 100, 2)).toFixed(1);
        displayResult(bmi);
        addToHistory(bmi, w);
    }

    function displayResult(bmi) {
        const area = document.getElementById('resultArea');
        const box = document.getElementById('resultBox');
        const val = document.getElementById('bmiValue');
        const badge = document.getElementById('statusBadge');
        const advice = document.getElementById('bmiAdvice');
        const indicator = document.getElementById('bmiIndicator');

        area.classList.remove('hidden');
        val.innerText = bmi;

        let config = {
            status: '正常',
            color: 'text-emerald-600',
            bg: 'bg-emerald-50',
            border: 'border-emerald-100',
            width: '50%', // 視覺比例
            text: '您的體態非常理想！建議維持目前的均衡飲食與運動習慣。繼續保持這份健康生活！'
        };

        if (bmi < 18.5) {
            config = { status: '過輕', color: 'text-sky-600', bg: 'bg-sky-50', border: 'border-sky-100', width: '20%', text: '目前的體重偏輕，建議增加優質蛋白質攝取，並透過重量訓練增加肌肉量。' };
        } else if (bmi >= 24 && bmi < 27) {
            config = { status: '過重', color: 'text-amber-600', bg: 'bg-amber-50', border: 'border-amber-100', width: '70%', text: '體重稍微超標，建議減少含糖飲料，每日快走 30 分鐘，將體位調整回健康範圍。' };
        } else if (bmi >= 27) {
            config = { status: '肥胖', color: 'text-rose-600', bg: 'bg-rose-50', border: 'border-rose-100', width: '90%', text: '數值顯示已進入肥胖範圍。建議設定小目標逐步減重，或諮詢醫師進行飲食管理。' };
        }

        // 動態更新 UI
        box.className = `p-6 rounded-3xl border-2 transition-all duration-500 ${config.bg} ${config.color} ${config.border}`;
        badge.className = `px-3 py-1 rounded-full text-xs font-black uppercase tracking-wider bg-white/80 shadow-sm ${config.color}`;
        badge.innerText = config.status;
        advice.innerText = config.text;
        
        // 觸發進度條動畫
        setTimeout(() => {
            indicator.style.width = config.width;
            indicator.className = `bmi-indicator ${config.color.replace('text', 'bg')}`;
        }, 50);
    }

    function addToHistory(bmi, weight) {
        const now = new Date();
        const time = `${now.getMonth()+1}/${now.getDate()} ${now.getHours()}:${String(now.getMinutes()).padStart(2, '0')}`;
        const item = { bmi, weight, time };
        
        history.unshift(item);
        if (history.length > 5) history.pop();
        updateHistoryUI();
    }

    function updateHistoryUI() {
        const list = document.getElementById('historyList');
        list.innerHTML = history.map(item => `
            <div class="history-item flex items-center justify-between p-3 bg-gray-50 rounded-xl">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-white flex items-center justify-center text-[10px] font-bold text-gray-400">
                        ${item.bmi}
                    </div>
                    <div>
                        <p class="text-xs font-bold text-gray-700">${item.weight} kg</p>
                        <p class="text-[10px] text-gray-400">${item.time}</p>
                    </div>
                </div>
                <i data-lucide="chevron-right" class="w-3 h-3 text-gray-300"></i>
            </div>
        `).join('');
        lucide.createIcons();
    }

    function clearHistory() {
        history = [];
        updateHistoryUI();
    }

    function showToast(msg) {
        // 簡單的自定義提示取代 alert
        const toast = document.createElement('div');
        toast.className = 'fixed top-10 left-1/2 -translate-x-1/2 bg-gray-800 text-white px-6 py-3 rounded-full text-sm font-medium z-50 shadow-2xl transition-all opacity-0';
        toast.innerText = msg;
        document.body.appendChild(toast);
        setTimeout(() => toast.style.opacity = '1', 10);
        setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
        }, 2500);
    }

    // 鍵盤支援
    document.addEventListener('keypress', (e) => { if(e.key === 'Enter') calculateBMI(); });
</script>

</body>
</html>
